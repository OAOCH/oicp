# ── OICP — variables de entorno ──────────────────────────────
# Copia este archivo a .env para desarrollo local. En Railway, configúralas
# en el panel del servicio (Variables). NINGÚN valor real debe commitearse.

# ── Núcleo (ya existentes en producción) ─────────────────────
# Puerto. En Railway lo inyecta la plataforma; localmente usa 3000.
PORT=3000
# Ruta de la base SQLite. En Railway apunta al volumen montado en /data.
DB_PATH=./data/oicp.db
# Clave maestra para scripts internos y subida de BD. Genera una larga y única.
# (Tras activar la auth por cookie, los endpoints /api/admin/* del panel usan
#  la sesión de superadmin; ADMIN_KEY queda solo para scripts como subir.mjs.)
ADMIN_KEY=cambia-esto-por-algo-largo-y-secreto
# production en Railway; development en local.
NODE_ENV=development

# ── Autenticación (magic link + whitelist) ───────────────────
# CLAVE DE ACTIVACIÓN: mientras JWT_SECRET esté vacío, la plataforma sigue
# ABIERTA (como hoy). En cuanto se define un secreto válido (>=32 bytes),
# la autenticación se activa y exige sesión. Esto permite desplegar el código
# primero y activar la auth después sin riesgo de tumbar producción.
# Genera con: openssl rand -hex 32
JWT_SECRET=
# URL pública para construir los magic links.
APP_URL=https://oicp-production.up.railway.app
# Correo del superadministrador. Se inserta como superadmin al migrar.
SUPERADMIN_EMAIL=oscar.obandoch@gmail.com
# Duración de la sesión (cookie) en días.
SESSION_LIFETIME_DAYS=14

# ── Email transaccional (Resend) ─────────────────────────────
# Sin esta clave, el magic link NO se envía por correo: queda en los logs del
# servidor (modo bootstrap, útil para el primer ingreso del superadmin).
# Crea una cuenta gratis en https://resend.com y pega aquí la API key.
RESEND_API_KEY=
# Remitente de los correos. Con dominio verificado en Resend usa el tuyo;
# de lo contrario, el sandbox onboarding@resend.dev funciona para pruebas.
MAIL_FROM=OICP <onboarding@resend.dev>

# ── CORS (opcional) ──────────────────────────────────────────
# Origen permitido para el navegador. Por defecto se usa APP_URL.
# CORS_ORIGIN=https://oicp-production.up.railway.app
